rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. ข้อมูลผู้ใช้งาน
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // 2. ข้อมูลคำสั่งซื้อ (Orders)
    match /orders/{orderId} {
      // ให้ทุกคนที่ล็อกอินสั่งของได้
      allow create: if request.auth != null;
      
      // ให้ลูกค้าทั่วไปดูได้เฉพาะออเดอร์ของตัวเอง
      allow read: if request.auth != null && resource.data.customer == request.auth.uid;
      
      // สิทธิ์พิเศษ: ให้ Seller (sattawat2560@gmail.com) ดูและจัดการออเดอร์ "ทั้งหมด" ได้ทันที
      allow read, write: if request.auth != null && 
        request.auth.token.email == "sattawat2560@gmail.com";
    }
    
    // 3. ส่วนอื่นๆ ของระบบ
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == "sattawat2560@gmail.com";
    }
  }
}
