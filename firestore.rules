rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 🛡️ ฟังก์ชันตรวจสอบสิทธิ์ Admin
    function isAdmin() {
      return request.auth != null && 
             request.auth.token != null &&
             request.auth.token.email != null &&
             request.auth.token.email.toLower() == "sattawat2560@gmail.com";
    }

    // 1. ข้อมูลผู้ใช้งาน (Users)
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // 2. ข้อมูลคำสั่งซื้อ (Orders)
    match /orders/{orderId} {
      allow create: if true;
      allow read: if (request.auth != null && (
        resource.data.customer == request.auth.uid ||
        resource.data.customer == request.auth.token.email
      )) || isAdmin();
      allow update: if (request.auth != null && (
        resource.data.customer == request.auth.uid ||
        resource.data.customer == request.auth.token.email
      )) || isAdmin() || (resource.data.status == "ที่ต้องชำระ");
      allow delete, write: if isAdmin();
    }
    
    // 3. ระบบคูปอง (Vouchers / Redemptions)
    match /vouchers/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /vouchers_redemptions/{document=**} {
      allow read, write: if request.auth != null;
    }
    match /voucher_qrs/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // 4. การตั้งค่าระบบ (Settings)
    match /settings/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // 5. ระบบแชท (Real-time Chat & Memory)
    match /chats/{chatId} {
      allow read, write: if request.auth != null || isAdmin();
      match /messages/{messageId} {
        allow read, write: if request.auth != null || isAdmin();
      }
    }
    
    // 6. ✅ ระบบจัดการสต๊อกสินค้า (Products)
    match /products/{productId} {
      allow read: if true;
      // ✅ อนุญาตให้เขียน/แก้ไขสต๊อกได้ตลอดเวลา (Usable Forever) ตามที่คุณลูกค้าต้องการครับ
      allow write: if true; 
    }
    
    // 7. ส่วนอื่นๆ (Fallback)
    match /{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
