rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 🛡️ Admin Verification - ONLY sattawat2560@gmail.com
    function isAdmin() {
      return request.auth != null && 
             request.auth.token != null &&
             request.auth.token.email != null &&
             request.auth.token.email.lower() == "sattawat2560@gmail.com";
    }

    // 1. User Profiles (Users own their data)
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // 2. Orders (Customers create, Admins manage)
    match /orders/{orderId} {
      allow create: if true;
      allow read: if request.auth != null && (
        resource.data.customer == request.auth.uid ||
        resource.data.customer == request.auth.token.email ||
        isAdmin()
      );
      allow update: if (request.auth != null && (
        resource.data.customer == request.auth.uid ||
        resource.data.customer == request.auth.token.email
      )) || isAdmin() || (resource.data.status == "ที่ต้องชำระ");
      allow delete: if isAdmin();
      allow write: if isAdmin();
    }
    
    // 3. Vouchers & Promotions (Admins manage)
    match /vouchers/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /vouchers_redemptions/{document=**} {
      allow read, write: if request.auth != null;
    }
    match /voucher_qrs/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ⚙️ Settings (Category management, etc.)
    match /settings/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // 5. Chat System
    match /chats/{chatId} {
      // Allow user to read/write if the chatId matches their email OR if they are the Admin
      allow read, write: if (request.auth != null && (
        chatId.lower() == request.auth.token.email.lower() || 
        isAdmin()
      )) || (
        // Fallback for cases where email might not be in token (e.g. some manual providers)
        // or if rules need to be more permissive for initial setup
        isAdmin()
      );
      
      match /messages/{messageId} {
        allow read, write: if (request.auth != null && (
          chatId.lower() == request.auth.token.email.lower() || 
          isAdmin()
        )) || (
          isAdmin()
        );
      }
    }

    // 6. Online Status
    match /status/{document=**} {
      allow read: if true;
      allow write: if true; // Simple status updates
    }
    
    // 7. General Fallback (Admins manage everything else)
    match /{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
