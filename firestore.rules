rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 🛡️ Admin Verification - ONLY sattawat2560@gmail.com
    function isAdmin() {
      return request.auth != null && 
             request.auth.token != null &&
             request.auth.token.email != null &&
             request.auth.token.email.toLower() == "sattawat2560@gmail.com";
    }

    // 1. User Profiles (Users own their data)
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // 2. Orders (Customers create, Admins manage)
    match /orders/{orderId} {
      allow create: if true;
      allow read: if request.auth != null && (
        resource.data.customer == request.auth.uid ||
        resource.data.customer == request.auth.token.email ||
        isAdmin()
      );
      allow update: if (request.auth != null && (
        resource.data.customer == request.auth.uid ||
        resource.data.customer == request.auth.token.email
      )) || isAdmin() || (resource.data.status == "ที่ต้องชำระ");
      allow delete: if isAdmin();
      allow write: if isAdmin();
    }
    
    // 3. Vouchers & Promotions (Admins manage)
    match /vouchers/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /vouchers_redemptions/{document=**} {
      allow read, write: if request.auth != null;
    }
    match /voucher_qrs/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ⚙️ Settings (Category management, etc.)
    match /settings/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // 4. Products & Settings (Admins manage everything else)
    match /{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
