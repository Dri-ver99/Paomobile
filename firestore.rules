rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // User Profiles
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Orders Collection
    match /orders/{orderId} {
      // 1. Any logged-in user can place an order
      allow create: if request.auth != null;
      
      // 2. Customers can read/update their own orders
      // 3. Seller (sattawat2560@gmail.com) can read/update ALL orders
      allow read, update: if request.auth != null && (
        (resource.data.customer == request.auth.uid) || 
        (request.auth.token.email == "sattawat2560@gmail.com")
      );
      
      // 4. Only seller can delete orders
      allow delete: if request.auth != null && request.auth.token.email == "sattawat2560@gmail.com";
    }
    
    // General read access for other collections (if any)
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == "sattawat2560@gmail.com";
    }
  }
}
