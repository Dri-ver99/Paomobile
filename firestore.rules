rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. ข้อมูลผู้ใช้งาน
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    match /orders/{orderId} {
      // ✅ อนุญาตให้ "ทุกคน" สั่งซื้อได้ (แก้ปัญหาคนอื่นสั่งแล้วไม่ขึ้น)
      allow create: if true;
      
      // ✅ เฉพาะ Admin (sattawat2560@gmail.com) หรือ "เจ้าของออเดอร์" เท่านั้นที่ดูข้อมูลได้
      allow read: if (request.auth != null && resource.data.customer == request.auth.uid) || 
                   (request.auth != null && request.auth.token.email == "sattawat2560@gmail.com");
      
      // ✅ เฉพาะ Admin เท่านั้นที่แก้ไขหรือลบออเดอร์ได้
      allow update, delete: if request.auth != null && request.auth.token.email == "sattawat2560@gmail.com";
    }
    
    // 3. ส่วนอื่นๆ ของระบบ
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == "sattawat2560@gmail.com";
    }
  }
}
