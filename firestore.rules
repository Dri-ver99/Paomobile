rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. ข้อมูลผู้ใช้งาน
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // 2. ข้อมูลคำสั่งซื้อ (Orders)
    match /orders/{orderId} {
      // ✅ ทุกคนสั่งซื้อได้ (รองรับทั้ง login และ guest)
      allow create: if true;
      
      // ✅ ลูกค้าดูออเดอร์ตัวเองได้
      allow read: if request.auth != null && (
        resource.data.customer == request.auth.uid ||
        resource.data.customer == request.auth.token.email
      );
      
      // ✅ ลูกค้าอัปเดตออเดอร์ตัวเองได้ (ยืนยันชำระเงิน + แนบสลีป)
      // อนุญาตให้ Guest อัปเดตได้ถ้าออเดอร์ยังอยู่ในสถานะ "ที่ต้องชำระ"
      allow update: if (request.auth != null && (
        resource.data.customer == request.auth.uid ||
        resource.data.customer == request.auth.token.email
      )) || (resource.data.status == "ที่ต้องชำระ");

      // ✅ Seller (sattawat2560@gmail.com) ใช้งานจัดการออเดอร์ทั้งหมด
      allow read, write: if request.auth != null && 
        request.auth.token.email == "sattawat2560@gmail.com";
    }
    
    // 3. ส่วนอื่นๆ ของระบบ
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == "sattawat2560@gmail.com";
    }
  }
}
