<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>เธฅเธเธเธทเนเธญเน€เธเนเธฒเนเธเน - Paomobile</title>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+Thai:wght@300;400;500;600;700&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: 'Noto Sans Thai', 'Outfit', sans-serif;
            background-color: #f7f7f9;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            color: #111;
        }
        .login-card {
            background-color: #ffffff;
            width: 100%;
            max-width: 480px;
            padding: 40px;
            border-radius: 24px;
            box-shadow: 0 4px 24px rgba(0,0,0,0.06);
            text-align: center;
        }
        .logo {
            width: 80px;
            height: auto;
            margin: 0 auto 32px auto;
            border-radius: 8px;
            object-fit: contain;
        }
        h1 {
            font-size: 24px;
            font-weight: 700;
            margin-bottom: 8px;
            text-align: left;
            letter-spacing: -0.02em;
        }
        .subtitle {
            font-size: 15px;
            color: #555;
            margin-bottom: 32px;
            text-align: left;
        }
        .btn-social {
            display: flex;
            align-items: center;
            justify-content: center;
            width: 100%;
            border: 1px solid #e5e7eb;
            background-color: #fff;
            padding: 14px;
            border-radius: 8px;
            font-size: 16px;
            font-weight: 500;
            cursor: pointer;
            margin-bottom: 12px;
            transition: background-color 0.2s;
            font-family: inherit;
        }

        .divider {
            display: flex;
            align-items: center;
            text-align: center;
            color: #777;
            font-size: 14px;
            margin-bottom: 24px;
        }
        .divider::before, .divider::after {
            content: '';
            flex: 1;
            border-bottom: 1px solid #e5e5e5;
        }
        .divider:not(:empty)::before { margin-right: 16px; }
        .divider:not(:empty)::after { margin-left: 16px; }

        .input-group {
            margin-bottom: 18px;
            text-align: left;
        }
        .input-group label {
            display: block;
            font-size: 14px;
            font-weight: 600;
            margin-bottom: 8px;
            color: #111;
        }
        .input-group input {
            width: 100%;
            padding: 14px 16px;
            border: 1px solid #e2e8f0;
            border-radius: 8px;
            font-size: 15px;
            font-family: inherit;
            color: #111;
            outline: none;
            transition: border-color 0.2s;
        }
        .input-group input:focus {
            border-color: #7fa9ee;
        }

        /* Registration Specific Styles */
        .card-header {
            display: flex;
            align-items: center;
            margin-bottom: 32px;
            position: relative;
        }
        .btn-back {
            background: none;
            border: none;
            cursor: pointer;
            padding: 0;
            color: #555;
            transition: color 0.2s;
            display: flex;
            align-items: center;
        }
        .btn-back:hover { color: #111; }
        
        .toggle-password {
    position: absolute;
    right: 15px;
    top: 50%;
    transform: translateY(-50%);
    cursor: pointer;
    color: #94a3b8;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.2s;
    user-select: none;
    z-index: 10;
}

.toggle-password:hover {
    color: #64748b;
}

.toggle-password svg {
    width: 20px;
    height: 20px;
    stroke-width: 2;
}
        .reg-title {
            position: absolute;
            left: 50%;
            transform: translateX(-50%);
            font-size: 26px;
            font-weight: 700;
            color: #1e293b;
            white-space: nowrap;
        }

        .password-input-wrapper {
            position: relative;
        }
        .consent-group {
            margin-bottom: 32px;
            text-align: left;
        }
        .consent-item {
            display: flex;
            align-items: flex-start;
            gap: 12px;
            margin-bottom: 12px;
            cursor: pointer;
            font-size: 14px;
            color: #4b5563;
            line-height: 1.5;
        }
        .consent-item input[type="checkbox"] {
            width: 22px;
            height: 22px;
            border-radius: 6px;
            border: 1px solid #d1d5db;
            margin-top: 1px;
            cursor: pointer;
            appearance: none;
            -webkit-appearance: none;
            background-color: #fff;
            position: relative;
        }
        .consent-item input[type="checkbox"]:checked {
            background-color: #fff;
            border-color: #d1d5db;
        }
        .consent-item input[type="checkbox"]:checked::after {
            content: 'โ“';
            position: absolute;
            left: 5px;
            top: -1px;
            color: #4b5563;
            font-size: 16px;
            font-weight: 700;
        }
        .consent-item span a {
            color: #7fa9ee;
            text-decoration: underline;
        }

        #loadingOverlay {
            position: fixed;
            top: 0; left: 0;
            width: 100%; height: 100%;
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(8px);
            display: none;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            z-index: 9999;
        }
        .spinner {
            width: 48px; height: 48px;
            border: 4px solid #f3f3f3;
            border-top: 4px solid #7fa9ee;
            border-radius: 50%;
            animation: spin 1s linear infinite;
        }
        @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }

        @media (max-width: 480px) {
            .login-card {
                padding: 32px 24px;
                box-shadow: none;
                border-radius: 0;
                min-height: 100vh;
            }
        }
        .auth-extra-links {
            display: flex;
            justify-content: space-between;
            margin-top: 12px;
        }
        .auth-extra-links a {
            font-size: 14px;
            color: #7fa9ee !important;
            text-decoration: underline !important;
            font-weight: 500;
        }

        /* Forgot Password Specific Styles */
        .forgot-pass-desc {
            font-size: 14px;
            color: #555;
            line-height: 1.6;
            margin-bottom: 32px;
            text-align: left;
        }
        .btn-link {
            background: none;
            border: none;
            color: #0b5edd;
            font-size: 15px;
            font-weight: 600;
            cursor: pointer;
            text-decoration: none;
            display: inline-block;
            margin-top: 24px;
            font-family: inherit;
        }
        .btn-link:hover {
            color: #094db3;
            text-decoration: underline;
        }

        /* Success View Styling */
        #successView {
            text-align: center;
            padding: 40px 20px;
        }
        .success-icon {
            width: 90px;
            height: 90px;
            background: #ecfdf5;
            color: #10b981;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 24px;
            box-shadow: 0 0 20px rgba(16, 185, 129, 0.1);
            animation: success-pulse 2s infinite;
        }
        @keyframes success-pulse {
            0% { transform: scale(1); box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.4); }
            70% { transform: scale(1.05); box-shadow: 0 0 0 15px rgba(16, 185, 129, 0); }
            100% { transform: scale(1); box-shadow: 0 0 0 0 rgba(16, 185, 129, 0); }
        }
        .success-icon svg {
            width: 50px;
            height: 50px;
        }
        .success-icon svg polyline {
            stroke-width: 4;
            stroke-dasharray: 100;
            animation: checkmark-draw 0.6s ease-in-out forwards;
        }
        @keyframes checkmark-draw {
            from { stroke-dashoffset: 100; opacity: 0; }
            to { stroke-dashoffset: 0; opacity: 1; }
        }
        .success-title {
            font-size: 24px;
            font-weight: 600;
            color: #1e293b;
            margin-bottom: 12px;
        }
        .success-text {
            color: #64748b;
            font-size: 16px;
            line-height: 1.5;
            margin-bottom: 32px;
        }
        .btn-continue {
            width: 100%;
